<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Store</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background-color: #f0f0f0; }
        .container { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 0 10px rgba(0,0,0,0.1); text-align: center; width: 80%; max-width: 800px; }
        .book-card { border: 1px solid #ccc; margin: 10px; padding: 10px; display: inline-block; vertical-align: top; width: 200px; }
        .book-card img { width: 100%; height: 250px; object-fit: cover; }
        .btn { padding: 5px 10px; text-decoration: none; border-radius: 3px; background: #007bff; color: white; border: none; cursor: pointer; }
        .btn-danger { background: #dc3545; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Book Store</h1>
        <a href="/add-book" class="btn">Add New Book</a>
        <hr>
        <% if (books.length === 0) { %>
            <div>
                <p>No books found.</p>
                <a href="/add-book" class="btn">Add Now</a>
            </div>
        <% } else { %>
            <div style="display: flex; flex-wrap: wrap; justify-content: center;">
                <% books.forEach(book => { %>
                    <div class="book-card">
                        <img src="/uploads/<%= book.image %>" alt="<%= book.title %>">
                        <h3><%= book.title %></h3>
                        <p>By <%= book.author %></p>
                        <a href="/edit-book/<%= book._id %>" class="btn">Edit</a>
                        <a href="/delete-book/<%= book._id %>" class="btn btn-danger" onclick="return confirm('Delete this book?')">Delete</a>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>
